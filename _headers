/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=()

# Force image/svg+xml on card art so X-Content-Type-Options: nosniff
# can't refuse to render it, and keep the cache short so future art
# swaps go live immediately.
/link-images/*
  Content-Type: image/svg+xml
  Cache-Control: public, max-age=300, must-revalidate

# Fibonacci Zoom card art (PNG, not SVG) — explicit Content-Type so
# nosniff doesn't block rendering.
/fibonacci-zoom/assets/images/*.png
  Content-Type: image/png
  Cache-Control: public, max-age=300, must-revalidate

# HTML, JS, CSS — browser must revalidate every request.
# Cloudflare Pages sets ETags automatically, so revalidation is
# a fast 304 when nothing changed — no wasted bandwidth.
/*.html
  Cache-Control: no-cache
/*.js
  Cache-Control: no-cache
/*.css
  Cache-Control: no-cache
/
  Cache-Control: no-cache

# App folders: same rule, catches nested paths
/collatz-cascade/*
  Cache-Control: no-cache
/fibonacci-zoom/*
  Cache-Control: no-cache
/moonlander/*
  Cache-Control: no-cache

# moonlander HTML + JS — stricter than the rule above so code edits
# land on F5 without hand-clearing the browser cache. Listed AFTER the
# /moonlander/* rule because Cloudflare Pages applies _headers in file
# order and the later matching value wins. Other moonlander assets
# (textures, GLBs, fonts) keep the broader no-cache rule above, which
# revalidates via ETag (304 when unchanged → small bandwidth cost).
/moonlander/index.html
  Cache-Control: no-store, must-revalidate
/moonlander/js/*
  Cache-Control: no-store, must-revalidate
