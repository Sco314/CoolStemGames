/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=()

# Force image/svg+xml on card art so X-Content-Type-Options: nosniff
# can't refuse to render it, and keep the cache short so future art
# swaps go live immediately.
/link-images/*
  Content-Type: image/svg+xml
  Cache-Control: public, max-age=300, must-revalidate

# Fibonacci Zoom card art (PNG, not SVG) — explicit Content-Type so
# nosniff doesn't block rendering.
/fibonacci-zoom/assets/images/*.png
  Content-Type: image/png
  Cache-Control: public, max-age=300, must-revalidate

# HTML, JS, CSS — browser must revalidate every request.
# Cloudflare Pages sets ETags automatically, so revalidation is
# a fast 304 when nothing changed — no wasted bandwidth.
/*.html
  Cache-Control: no-cache
/*.js
  Cache-Control: no-cache
/*.css
  Cache-Control: no-cache
/
  Cache-Control: no-cache

# App folders: same rule, catches nested paths
/collatz-cascade/*
  Cache-Control: no-cache
/fibonacci-zoom/*
  Cache-Control: no-cache
/moonlander/*
  Cache-Control: no-cache
